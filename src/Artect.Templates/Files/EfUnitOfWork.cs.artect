using {{ ApplicationPortsNamespace }};
using {{ DataNamespace }};

namespace {{ Namespace }};

public sealed class EfUnitOfWork : IUnitOfWork
{
    readonly {{ DbContextTypeName }} _db;
    public EfUnitOfWork({{ DbContextTypeName }} db) => _db = db;

    public System.Threading.Tasks.Task<int> CommitAsync(System.Threading.CancellationToken ct = default)
        => _db.SaveChangesAsync(ct);
}
