using System.Collections.Generic;
using System.Linq;
using {{ ErrorsNamespace }};
using {{ SharedErrorsNamespace }};

namespace {{ Namespace }};

internal static class ApplicationErrorMappers
{
    public static ValidationError ToWire(this ApplicationError e) => new(e.Field, e.Code, e.Message);

    public static IReadOnlyList<ValidationError> ToWire(this IReadOnlyList<ApplicationError> errors) =>
        errors.Select(e => e.ToWire()).ToArray();
}
