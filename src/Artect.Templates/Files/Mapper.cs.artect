    /// <summary>Maps a <see cref="Create{{ EntityName }}Request"/> to a <see cref="{{ EntityName }}Dto"/> (server assigns PK).</summary>
    public static {{ EntityName }}Dto ToDto(this Create{{ EntityName }}Request request) => new()
    {
{{# for col in NonPkColumns }}
        {{ col.PropertyName }} = request.{{ col.PropertyName }},
{{/for}}
    };

    /// <summary>Applies a <see cref="Update{{ EntityName }}Request"/> patch onto an existing <see cref="{{ EntityName }}Dto"/>.</summary>
    public static {{ EntityName }}Dto Update(this {{ EntityName }}Dto dto, Update{{ EntityName }}Request request)
    {
{{# for col in NonPkColumns }}
        dto.{{ col.PropertyName }} = request.{{ col.PropertyName }};
{{/for}}
        return dto;
    }

    static partial void OnMapped({{ EntityName }} entity, {{ EntityName }}Dto dto);
    static partial void OnMapped({{ EntityName }}Dto dto, {{ EntityName }}Response response);
}
