    public static {{ EntityName }}Dto ToDto(this {{ EntityName }} entity)
    {
        var dto = new {{ EntityName }}Dto
        {
{{# for col in Columns }}
            {{ col.PropertyName }} = entity.{{ col.PropertyName }},
{{/for}}
        };
        OnMapped(entity, dto);
        return dto;
    }

    /// <summary>Maps a <see cref="{{ EntityName }}Dto"/> back to a <see cref="{{ EntityName }}"/> entity.</summary>
    public static {{ EntityName }} ToEntity(this {{ EntityName }}Dto dto) => new()
    {
{{# for col in Columns }}
        {{ col.PropertyName }} = dto.{{ col.PropertyName }},
{{/for}}
    };

    /// <summary>Maps a <see cref="{{ EntityName }}Dto"/> to a <see cref="{{ EntityName }}Response"/>.</summary>
    public static {{ EntityName }}Response ToResponse(this {{ EntityName }}Dto dto)
    {
        var response = new {{ EntityName }}Response
        {
{{# for col in Columns }}
            {{ col.PropertyName }} = dto.{{ col.PropertyName }},
{{/for}}
        };
